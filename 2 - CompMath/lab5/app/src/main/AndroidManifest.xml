<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.interpolation">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Интерполяция"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="Интерполяция функций">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".ManualInputActivity"
            android:label="Ввод с клавиатуры"
            android:parentActivityName=".MainActivity"/>

        <activity
            android:name=".FileInputActivity"
            android:label="Загрузка из файла"
            android:parentActivityName=".MainActivity"/>

        <activity
            android:name=".FunctionInputActivity"
            android:label="Выбор функции"
            android:parentActivityName=".MainActivity"/>

        <activity
            android:name=".ResultActivity"
            android:label="Результаты"
            android:parentActivityName=".MainActivity"/>
    </application>
</manifest>
