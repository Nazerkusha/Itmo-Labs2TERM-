<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F8F9FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Интерполяция функций"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Лагранж · Ньютон · Стирлинг · Бессель"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnManual"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="✏️  Ввод с клавиатуры"
        android:textSize="16sp"
        android:backgroundTint="#1565C0"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnFile"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="📂  Загрузить из файла"
        android:textSize="16sp"
        android:backgroundTint="#388E3C"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnFunction"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="𝑓(x)  Выбрать функцию"
        android:textSize="16sp"
        android:backgroundTint="#E53935"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ИТМО · Вычислительная математика · 2026"
        android:textSize="11sp"
        android:textColor="#AAAAAA"
        android:layout_marginTop="40dp"/>
</LinearLayout>
